\f0\fs24 \cf0 \{\
  "$schema": "http://json-schema.org/draft-07/schema#",\
  "title": "Geometrical IP Lock (GIL) Invariants Schema",\
  "description": "Deterministic tolerances for pixel-perfect identity preservation in generated variations.",\
  "type": "object",\
  "properties": \{\
    "gil_id": \{\
      "type": "string",\
      "description": "Unique cryptographic hash of the source 3D asset (mold)."\
    \},\
    "silhouette_mask": \{\
      "type": "object",\
      "properties": \{\
        "max_drift_px": \{\
          "type": "integer",\
          "description": "Maximum allowed pixel drift outside the canonical SAM2 mask boundaries.",\
          "default": 1\
        \},\
        "action": \{\
          "type": "string",\
          "enum": ["REJECT", "RESAMPLE", "WARN"]\
        \}\
      \},\
      "required": ["max_drift_px", "action"]\
    \},\
    "depth_map_consistency": \{\
      "type": "object",\
      "properties": \{\
        "min_iou": \{\
          "type": "number",\
          "description": "Minimum Intersection over Union (IoU) required between the source depth map and the generated depth map.",\
          "minimum": 0.0,\
          "maximum": 1.0\
        \},\
        "action": \{\
          "type": "string",\
          "enum": ["REJECT", "RESAMPLE"]\
        \}\
      \},\
      "required": ["min_iou", "action"]\
    \}\
  \},\
  "required": ["gil_id", "silhouette_mask", "depth_map_consistency"]\
\}}